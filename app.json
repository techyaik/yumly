{
  "expo": {
    "name": "Yumly",
    "slug": "yumly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo/icon.png",
    "scheme": "yumly",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aik.yumly"
    },
    "android": {
      "package": "com.aik.yumly",
      "permissions": [],
      "adaptiveIcon": {
        "backgroundColor": "#0E0E10",
        "backgroundImage": "./assets/images/logo/adaptive-icon/background.png",
        "foregroundImage": "./assets/images/logo/adaptive-icon/foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "runtimeVersion": "1.0.0",
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo/favicon.png",
      "baseUrl": "/yumly"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0D0D0F",
          "dark": {
            "backgroundColor": "#0D0D0F",
            "image": "./assets/images/logo/splash.png"
          }
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-web-browser",
      "expo-font",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "af166135-3a0d-4a63-b90d-26c2cdd82fff"
      }
    },
    "owner": "aik7"
  }
}
